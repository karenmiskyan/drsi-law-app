.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies — never committed
**/node_modules/
**/vendor/
**/.npm/

# Builds — generated, not committed
**/dist/
**/build/
